diff --git a/src/components/SystemStatusWidget.tsx b/src/components/SystemStatusWidget.tsx
new file mode 100644
index 0000000..0e44f87
--- /dev/null
+++ b/src/components/SystemStatusWidget.tsx
@@ -0,0 +1,44 @@
+import { useEffect, useState } from 'react';
+import { systemService } from '../core/api';
+import type { SystemStatus } from '../core/types';
+
+export function SystemStatusWidget() {
+  const [status, setStatus] = useState<SystemStatus | null>(null);
+  const [loading, setLoading] = useState(true);
+
+  useEffect(() => {
+    async function checkStatus() {
+      try {
+        const result = await systemService.getStatus();
+        setStatus(result);
+      } catch (err) {
+        console.error('Failed to get status:', err);
+      } finally {
+        setLoading(false);
+      }
+    }
+    
+    checkStatus();
+  }, []);
+
+  if (loading) {
+    return <p className="text-zulu-muted font-sans">Loading system status...</p>;
+  }
+
+  if (!status) {
+    return <p className="text-red-400 font-sans">Failed to load system status.</p>;
+  }
+
+  return (
+    <div className="bg-zulu-surface p-6 rounded-lg border border-zulu-border" data-testid="system-status">
+      <h2 className="text-xl font-semibold mb-4 font-sans text-zulu-accent">System Health Overview</h2>
+      <ul className="space-y-2 text-zulu-text font-mono text-sm">
+        <li>
+          Status: <span className={status.status === 'online' ? 'text-zulu-success font-bold' : 'text-red-400 font-bold'}>{status.status}</span>
+        </li>
+        <li>Version: {status.version}</li>
+        <li>Modules: {status.active_modules.join(', ') || 'None'}</li>
+      </ul>
+    </div>
+  );
+}
