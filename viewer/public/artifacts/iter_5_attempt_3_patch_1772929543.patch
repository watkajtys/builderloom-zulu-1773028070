@@ -0,0 +1,135 @@
+import pytest
+import os
+import threading
+from backend.state import ConductorState, BacklogTask, TaskType, TaskPriority
+import backend.state
+from pydantic import ValidationError
+
+@pytest.fixture(autouse=True)
+def clean_state_files():
+    # Remove state files before and after each test
+    for file in ['session_state.json', 'execution_state.json']:
+        if os.path.exists(file):
+            os.remove(file)
+    backend.state._global_state = None
+    yield
+    for file in ['session_state.json', 'execution_state.json']:
+        if os.path.exists(file):
+            os.remove(file)
+    backend.state._global_state = None
+
+def test_conductor_state_initialization():
+    state = ConductorState()
+    assert state.schema_version == "1.0.0"
+    assert state.current_iteration == 0
+    assert state.active_branch == "main"
+
+def test_conductor_state_singleton():
+    state1 = ConductorState.load()
+    state2 = ConductorState.load()
+    assert id(state1) == id(state2)
+
+def test_conductor_state_save_and_load():
+    state = ConductorState.load()
+    state.project_name = "Loom Experiment"
+    state.active_task_id = "TASK-123"
+    state.save()
+
+    # Reset in-memory state to force load from disk
+    backend.state._global_state = None
+    loaded_state = ConductorState.load()
+    
+    assert loaded_state.project_name == "Loom Experiment"
+    assert loaded_state.active_task_id == "TASK-123"
+    
+def test_execution_state_split():
+    state = ConductorState.load()
+    state.current_status = "Active"
+    state.save()
+    
+    assert os.path.exists("session_state.json")
+    assert os.path.exists("execution_state.json")
+    
+    import json
+    with open("execution_state.json", "r") as f:
+        exec_data = json.load(f)
+        
+    assert exec_data["schema_version"] == "1.0.0"
+    assert "ui_containers" in exec_data
+    assert "ui_agents" in exec_data
+    assert "ui_metrics" in exec_data
+    assert exec_data["ui_metrics"]["systemHealth"] == 100
+
+def test_backlog_task_validation():
+    # Valid task
+    task = BacklogTask(
+        id="T1",
+        type=TaskType.FEATURE,
+        priority=TaskPriority.P1_HIGH,
+        description="Test feature"
+    )
+    assert task.id == "T1"
+    
+    # Invalid task (missing required fields)
+    with pytest.raises(ValidationError):
+        BacklogTask(id="T2")
+
+def test_add_log():
+    state = ConductorState.load()
+    state.add_log("Test log entry")
+    
+    assert "Test log entry" in state.live_logs
+    
+def test_log_rotation():
+    state = ConductorState.load()
+    for i in range(600):
+        state.add_log(f"Log {i}")
+        
+    assert len(state.live_logs) == 500
+    assert state.live_logs[-1] == "Log 599"
+    assert state.live_logs[0] == "Log 100"
+
+def test_overseer_initialization():
+    from loom.core.overseer import Overseer
+    
+    # Simple check that we can import and instantiate it
+    try:
+        overseer = Overseer()
+        assert overseer is not None
+    except Exception as e:
+        pytest.fail(f"Overseer initialization failed: {e}")
+
+
+def test_overseer_fault_handling():
+    from loom.core.overseer import Overseer
+    import traceback
+    
+    class FaultyOverseer(Overseer):
+        def loop(self):
+            self.state = ConductorState.load()
+            while True:
+                try:
+                    raise RuntimeError("Intentional Agent Node Failure")
+                except Exception as e:
+                    error_trace = traceback.format_exc()
+                    import logging
+                    logger = logging.getLogger("loom")
+                    logger.error(f"Critical loop error: {e}\n{error_trace}")
+                    self.state.add_log(f"TELEMETRY_ERROR: Critical agent loop exception: {e}")
+                    self.state.current_status = "CRITICAL_ERROR"
+                    self.state.shutdown_requested = True
+                    self.state.save()
+                    break
+
+    # Prevent git init failures if directory isn't setup
+    o = FaultyOverseer()
+    
+    # We override the actual call to loop so it doesn't try anything else
+    o.loop()
+    
+    state = ConductorState.load()
+    assert state.shutdown_requested is True
+    assert state.current_status == "CRITICAL_ERROR"
+    
+    has_telemetry = any("TELEMETRY_ERROR: Critical agent loop exception: Intentional Agent Node Failure" in log for log in state.live_logs)
+    assert has_telemetry is True
