+import { useLocation } from 'react-router-dom';
+
+export default function Header() {
+  const location = useLocation();
+
+  const getPageTitle = (pathname: string) => {
+    switch (pathname) {
+      case '/':
+        return 'Dashboard';
+      case '/agents':
+        return 'Agents';
+      default:
+        return 'Unknown Route';
+    }
+  };
+
