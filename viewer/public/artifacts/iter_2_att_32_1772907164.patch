+        { agentId: 'overseer-beta', state: 'reflecting', currentTask: 'Analyzing iteration metrics', happinessScore: 10 }
+      ]);
+    }, 400);
+  });
+};
+
+export const fetchSystemMetrics = async (): Promise<OrchestrationMetrics> => {
+  return new Promise((resolve) => {
+    setTimeout(() => {
+      resolve({
+        activeContainers: 2,
+        agentCount: 2,
+        systemHealth: 95
+      });
+    }, 200);
+  });
+};
