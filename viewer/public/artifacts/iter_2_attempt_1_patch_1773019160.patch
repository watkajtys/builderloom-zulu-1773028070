+test('Verify duplication removed on roadmap view', async ({ page }) => {
+  await page.goto('/viewer/index.html?view=roadmap');
+  
+  // Verify 'Strategic Roadmap' text appears only once (as the main header outside the card container or as the singular header).
+  await expect(page.getByText('Strategic Roadmap')).toHaveCount(1);
+  
+  // Verify the 'Future milestones and factory goals.' text does not appear in the card content.
+  // Wait, the main subheader actually says: "Future milestones and factory goals." as well. Let's check the DOM structure.
+  // Wait, I completely removed it from the card. Does it appear elsewhere?
+  // Let's verify the outer one exists and the inner one doesn't.
+  // The outer one was: <p className="text-[var(--zulu-muted)] mt-1 font-medium">{viewSubtitles[currentView] || "Managing factory state..."}</p>
+  // Its text is: "Future milestones and strategic planning..." not "Future milestones and factory goals."
+  // So 'Future milestones and factory goals.' should be completely gone.
+  await expect(page.getByText('Future milestones and factory goals.')).toHaveCount(0);
+
+  // The main header should still have Strategic Roadmap
+  await expect(page.getByText('Strategic Roadmap')).toHaveCount(1);
+
+  await page.screenshot({ path: 'evidence.png' });
+});
