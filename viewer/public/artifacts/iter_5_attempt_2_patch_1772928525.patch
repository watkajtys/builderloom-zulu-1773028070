index 0000000..33b1d85
--- /dev/null
+++ b/tests/test_core.py
@@ -0,0 +1,163 @@
+import os
+import json
+import pytest
+from backend.state import ConductorState, BacklogTask, TaskType, TaskPriority
+
+@pytest.fixture(autouse=True)
+def clean_state_files():
+    import backend.state
+    # Setup
+    if os.path.exists("session_state.json"):
+        os.remove("session_state.json")
+    if os.path.exists("execution_state.json"):
+        os.remove("execution_state.json")
+    
+    # Reset in-memory state properly so we test disk interactions
+    backend.state._global_state = None
+    
+    yield
+    
+    # Teardown
+    if os.path.exists("session_state.json"):
+        os.remove("session_state.json")
+    if os.path.exists("execution_state.json"):
+        os.remove("execution_state.json")
+
+def test_state_initialization():
+    state = ConductorState.load()
+    assert state.schema_version == "1.0.0"
+    assert state.current_iteration == 0
+    assert len(state.backlog) == 0
+
+def test_state_save_and_load():
+    import backend.state
+    state = ConductorState.load()
+    state.project_name = "Test Project"
+    state.active_task_id = "TASK-123"
+    state.backlog.append(BacklogTask(
+        id="TASK-123",
+        type=TaskType.FEATURE,
+        priority=TaskPriority.P1_HIGH,
+        description="Test task"
+    ))
+    
+    state.save()
+    
+    # Verify files were created
+    import time
+    time.sleep(0.5) # ensure flushed to disk
+    assert os.path.exists("session_state.json")
+    assert os.path.exists("execution_state.json")
+    
+    # Force reload from disk
+    backend.state._global_state = None
+    loaded_state = ConductorState.load()
+    
+    assert loaded_state.project_name == "Test Project"
+    assert loaded_state.active_task_id == "TASK-123"
+    assert len(loaded_state.backlog) == 1
+    assert loaded_state.backlog[0].description == "Test task"
+
+def test_state_decoupling_schema():
+    state = ConductorState.load()
+    state.save()
+    
+    # Read files directly to check schema separation
+    with open("session_state.json", "r") as f:
+        session_data = json.load(f)
+        
+    with open("execution_state.json", "r") as f:
+        execution_data = json.load(f)
+        
+    # Check session state excludes UI fields
+    assert "schema_version" in session_data
+    assert "ui_containers" not in session_data
+    assert "ui_agents" not in session_data
+    
+    # Check execution state includes UI fields
+    assert "schema_version" in execution_data
+    assert "ui_containers" in execution_data
+    assert "ui_agents" in execution_data
+    assert "ui_metrics" in execution_data
+
+from loom.core.overseer import Overseer
+from unittest.mock import MagicMock, patch
+
+class FaultyOverseer(Overseer):
+    def __init__(self, *args, **kwargs):
+        # Prevent actual initialization to avoid missing environment variables
+        self.state = ConductorState.load()
+        self.git = MagicMock()
+        self.jules = MagicMock()
+        self.stitch = MagicMock()
+        self.phoenix = MagicMock()
+        self.app_screenshot = None
+        
+    def _check_for_updates(self):
+        pass
+        
+    def _refresh_db_stats(self):
+        pass
+        
+    def _consume_steering(self):
+        pass
+        
+    def _check_shutdown(self):
+        pass
+        
+    def ensure_scaffold(self):
+        pass
+
+def test_overseer_exception_boundary(mocker):
+    """
+    Test that an exception thrown inside the overseer loop is caught, 
+    telemetry is logged, and the loop terminates gracefully (shutdown_requested=True).
+    """
+    
+    overseer = FaultyOverseer()
+    overseer.state.current_status = "Active"
+    
+    # Mock the vibe check to raise an exception
+    mocker.patch.object(overseer, 'app_screenshot', new="dummy.png")
+    overseer.vibe = MagicMock()
+    overseer.vibe.check_vibe.side_effect = RuntimeError("Intentional Loop Failure")
+    
+    # We'll just run a single iteration of what would be inside the loop
+    # by directly invoking the code that we know throws the error to verify
+    # the error handling logic, or we can use the loop but mock the infinite part.
+    
+    # To test the actual loop's error boundary, we override the entire while True block's inner part
+    # but the easiest way is to mock a method called in the loop and verify `shutdown_requested`
+    
+    # A cleaner approach to test loop exception boundary without actually looping infinitely:
+    # We patch the `_check_for_updates` to raise an error.
+    overseer._check_for_updates = MagicMock(side_effect=RuntimeError("Intentional Root Failure"))
+    
+    # Run the loop. It should catch the error, log it, and break out.
+    overseer.loop()
+    
+    # Reload state to verify the effects
+    state = ConductorState.load()
+    
+    # Verify the exception was handled
+    assert state.shutdown_requested is True
+    assert state.current_status == "CRITICAL_ERROR"
+    
+    # Verify telemetry was added
+    has_error_log = any("TELEMETRY_ERROR: Critical agent loop exception" in log for log in state.live_logs)
+    assert has_error_log is True
+
+def test_overseer_retry_logic():
+    """
+    Test the overseer initializes correctly without crashing when mocking dependencies
+    (e.g., simulating a successful instantiation but without API keys).
+    """
+    with patch('loom.core.overseer.GitClient'):
+        with patch('loom.core.overseer.PhoenixServer'):
+            with patch('loom.core.overseer.StitchClient'):
+                with patch('loom.core.overseer.MockJulesClient'):
+                    with patch('loom.core.overseer.JulesClient'):
+                        with patch('os.getenv', return_value="True"): # USE_MOCK_JULES
+                            overseer = Overseer()
+                            assert overseer.state is not None
+                            assert overseer.jules is not None
